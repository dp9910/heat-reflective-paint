&CONTROL
   calculation      = 'scf'
   restart_mode     = 'from_scratch'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './out'
   prefix           = 'Ca2O4Si'
   disk_io          = 'low'
   pseudo_dir       = '/data/pseudopotentials'
/
&SYSTEM
   ibrav            = 0
   ecutwfc          = 50
   ecutrho          = 400
   nosym            = .true.
   occupations      = 'fixed'
   ntyp             = 3
   nat              = 28
/
&ELECTRONS
   electron_maxstep = 200
   conv_thr         = 1e-10
   mixing_beta      = 0.3
/
&IONS
/
