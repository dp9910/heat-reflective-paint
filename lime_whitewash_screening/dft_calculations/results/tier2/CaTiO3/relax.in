&CONTROL
   calculation      = 'vc-relax'
   restart_mode     = 'from_scratch'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './out'
   prefix           = 'CaO3Ti'
   etot_conv_thr    = 1e-05
   forc_conv_thr    = 0.0001
   disk_io          = 'low'
   pseudo_dir       = '/data/pseudopotentials'
/
&SYSTEM
   ibrav            = 0
   ecutwfc          = 50
   ecutrho          = 400
   occupations      = 'smearing'
   degauss          = 0.005
   smearing         = 'gaussian'
   ntyp             = 3
   nat              = 20
/
&ELECTRONS
   electron_maxstep = 150
   conv_thr         = 1e-08
   mixing_beta      = 0.3
/
&IONS
   ion_dynamics     = 'bfgs'
/
&CELL
   cell_dynamics    = 'bfgs'
   press_conv_thr   = 0.5
/
ATOMIC_SPECIES
Ca 40.078 Ca.pbe-spn-kjpaw_psl.1.0.0.UPF
Ti 47.867 ti_pbe_v1.4.uspp.F.UPF
O 15.999 O.pbe-n-kjpaw_psl.0.1.UPF

