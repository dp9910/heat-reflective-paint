&CONTROL
   calculation      = 'vc-relax'
   restart_mode     = 'from_scratch'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './out2'
   prefix           = 'Ca3O8P2'
   etot_conv_thr    = 1e-05
   forc_conv_thr    = 0.0001
   disk_io          = 'low'
   pseudo_dir       = '/data/pseudopotentials'
/
&SYSTEM
   ibrav            = 0
   ecutwfc          = 50
   ecutrho          = 400
   occupations      = 'smearing'
   degauss          = 0.005
   smearing         = 'gaussian'
   ntyp             = 3
   nat              = 13
/
&ELECTRONS
   electron_maxstep = 150
   conv_thr         = 1e-08
   mixing_beta      = 0.3
/
&IONS
   ion_dynamics     = 'bfgs'
/
&CELL
   cell_dynamics    = 'bfgs'
   press_conv_thr   = 0.5
/
